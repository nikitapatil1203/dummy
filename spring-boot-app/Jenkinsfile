pipeline {
  agent any 
    stages {
      stage(compile) {
        steps{
          sh 'mvn clean compile'
        }
      }
      stage(build) {
        steps {
          sh 'mvn -version'
          sh 'java -version'
          sh 'cd spring-boot-app && mvn clean compile && mvn clean package'
        }






        
      }
    }
  


  
}
