pipeline {
  agent any 
    environment {
           DOCKER_IMAGE = "nikitapatil1203/ci-cd:${BUILD_NUMBER}"
           SONAR_URL = "http://**.***.**.***:9000/"
           TRIVY_CACHE_DIR = "${WORKSPACE}/.trivy_cache"
           AWS_REGION = "us-east-1"
           AWS_ACCOUNT_ID = credentials('aws-account-id')
        }
    stages {
      stage('Checkout') {
         steps {
            sh 'echo passed'
         // sh 'git branch: 'main', url: 'https://github.com/nikitapatil1203/CI-CD''
         }
       }      
      stage('Build and Test') {
         steps {
            sh 'cd spring-boot-app && mvn clean package'
         }
       }      
  //  stage('Static Code Analysis') {
    //   steps {
    //      withCredentials([string(credentialsId: 'sonarqube', variable: 'SONAR_AUTH_TOKEN')]) {
    //      sh 'cd spring-boot-app && mvn sonar:sonar -Dsonar.login=$SONAR_AUTH_TOKEN -Dsonar.host.url=${SONAR_URL}'
    //      }
    //    }
    //  }
      stage('Build Image'){
        steps{
            sh 'cd spring-boot-app && docker build -t ${DOCKER_IMAGE} .'
            sh 'docker images'
        }
      }
      stage('Trivy Docker Image Scan') {
         steps {
          sh '''
            trivy image \
            --timeout 20m \
            --scanners vuln \
            --severity HIGH,CRITICAL \
            --skip-version-check \
            --cache-dir ${TRIVY_CACHE_DIR} \
            ${DOCKER_IMAGE}
            '''
            }
      }
      stage('Push Docker Image To ECR') {
        steps {
          // Refer to AWS ECR for the commands
            sh '''
            aws ecr get-login-password --region ${AWS_REGION} | docker login --username AWS --password-stdin ${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com
            docker tag ${DOCKER_IMAGE} ${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/nikita/ci-cd-repo:latest
            docker push ${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/nikita/ci-cd-repo:latest
            '''          
        }
      }
      stage('Update Deployment File') {
        steps {
          sh 'echo passed'
        }
      }





        
      }
    }
  


  

